[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/EquipmentDetailsScreen.gd" id="1_details"]

[node name="EquipmentDetailsScreen" type="PanelContainer"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
script = ExtResource("1_details")

[node name="Margin" type="MarginContainer" parent="."]
layout_mode = 2
theme_override_constants/margin_left = 18
theme_override_constants/margin_top = 16
theme_override_constants/margin_right = 18
theme_override_constants/margin_bottom = 16

[node name="OuterLayout" type="VBoxContainer" parent="Margin"]
layout_mode = 2
theme_override_constants/separation = 10

[node name="ContentScroll" type="ScrollContainer" parent="Margin/OuterLayout"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
horizontal_scroll_mode = 0

[node name="Content" type="VBoxContainer" parent="Margin/OuterLayout/ContentScroll"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="Heading" type="Label" parent="Margin/OuterLayout/ContentScroll/Content"]
layout_mode = 2
text = "EQUIPMENT DETAILS"

[node name="TitleLabel" type="Label" parent="Margin/OuterLayout/ContentScroll/Content"]
