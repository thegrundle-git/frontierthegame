[ext_resource type="Script" path="res://scripts/resources/JournalFragmentData.gd" id="1_fragment"]

[resource]
script = ExtResource("1_fragment")
id = "fragment_beneath_ashes"
display_name = "Fragment Beneath the Ashes"
attribution = "Unknown"
physical_description = "A smoke-darkened scrap of writing material, brittle at the edges and creased from being folded many times. No name or identifying mark survives."
body = "The fire lasted through the rain, though only just. I marked the river stone before returning so the crossing would not be lost again. If the water rises, the grooves should remain above it."
event_id = "fragment_beneath_ashes"
