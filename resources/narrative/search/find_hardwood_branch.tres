variants = Array[String](["Beneath an older tree, {actor_name} found a Hardwood Branch with dense, straight grain.", "A fallen limb had split around a sound length of hardwood suitable for careful shaping.", "Among the soft deadfall, one heavy Hardwood Branch remained firm and unrotted."])
