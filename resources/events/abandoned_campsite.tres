[sub_resource type="Resource" id="Resource_pt8ql"]
script = ExtResource("1_dedps")
id = "investigate"
display_text = "Investigate the campsite"
intent_text = "Search the abandoned camp for usable supplies and evidence."
reward_hint = "Possible provisions, basic materials, Exploration experience, and Knowledge."
cost_or_risk_text = "Requires 45 minutes among unstable, decayed remains."
uncertainty_text = "What was left behind, and why the camp was abandoned, are unknown."
result_text = "{actor_name} searches through the abandoned camp. Most of it has rotted away, but a few useful supplies remain."
rewards = Array[ExtResource("2_n165k")]([SubResource("Resource_n165k"), SubResource("Resource_tb2nd")])
skill_id = "exploration"
xp_reward = 4
knowledge_reward = 2
game_minutes = 45
metadata/_custom_type_script = "uid://cqst562t271uf"

[sub_resource type="Resource" id="Resource_70lvn"]
script = ExtResource("1_dedps")
id = "leave"
display_text = "Leave it undisturbed"
intent_text = "Avoid disturbing the campsite and return to the trail."
reward_hint = "Minor Exploration experience; no material reward expected."
cost_or_risk_text = "No additional time or immediate risk."
uncertainty_text = "Anything still inside the camp will remain undiscovered."
result_text = "{actor_name} decides the abandoned camp is not worth the risk and quietly returns to the trail."
skill_id = "exploration"
xp_reward = 1
metadata/_custom_type_script = "uid://cqst562t271uf"

[resource]
script = ExtResource("2_ycqud")
id = "abandoned_campsite"
display_name = "Abandoned Campsite"
description = "Beyond a wall of tangled brush, {actor_name} finds the remains of a small campsite. The fire has long gone cold, but a torn pack still rests beside the ashes."
