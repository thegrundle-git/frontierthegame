[resource]
script = ExtResource("2_recipe")
id = "stone_axe_recipe"
display_name = "Assemble Axe"
ingredients = Array[ExtResource("1_ingredient")]([SubResource("Ingredient_head"), SubResource("Ingredient_handle"), SubResource("Ingredient_binding")])
results = Array[ExtResource("1_ingredient")]([SubResource("Result_stone_axe")])
craft_time = 30
xp_reward = 5
variant_component_slot = "head"
material_result_variants = Array[ExtResource("7_variant")]([SubResource("Variant_flint")])
description = "Seat the best available shaped head against the prepared handle, then lash the joint tightly with twisted fiber. The head material determines the finished axe."
metadata/_custom_type_script = "uid://ck8q7c4l76io2"
