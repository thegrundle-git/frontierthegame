[sub_resource type="Resource" id="Ingredient_handle"]
script = ExtResource("1_ingredient")
item = ExtResource("3_handle")

[sub_resource type="Resource" id="Ingredient_binding"]
script = ExtResource("1_ingredient")
item = ExtResource("4_binding")

[sub_resource type="Resource" id="Result_flint_axe"]
