[resource]
script = ExtResource("2_tisep")
id = "river"
display_name = "River"
description = "A natural freshwater watercourse that supports the surrounding environment. A dependable source of water and a common place to find useful resources."
first_visit_text = "The trees break around a ribbon of cold, moving water. Smooth stones line the bank, while broken branches and dark silt collect where the current slows. For the first time, the wilderness seems to offer a path rather than a wall."
available_actions = Array[ExtResource("1_tisep")]([ExtResource("2_lq47s"), ExtResource("9_track")])
travel_connections = Array[ExtResource("3_lq47s")]([SubResource("Resource_b71gb")])
