display_name = "Meadow"
description = "Tall grass sways gently in the breeze, concealing herbs, flowers, and the occasional wandering animal. The open land feels peaceful, but even peaceful places can hide danger."
first_visit_text = "The forest thins behind Finnley as the world suddenly opens. Tall grass rolls beneath the wind, carrying the sound of insects and distant birds. The wilderness is larger than it first appeared."
